# ── 데이터베이스 ─────────────────────────────────────────────
# 로컬: postgresql://USER@localhost:5432/timetable
#
# Supabase (Vercel 배포):
#   DATABASE_URL — Transaction pooler (포트 6543), Prisma용 ?pgbouncer=true 포함
#   DIRECT_URL   — Direct connection (포트 5432), migrate deploy 전용 (Vercel 빌드·로컬 마이그레이션)
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/timetable
DIRECT_URL=

# ── 인증 ─────────────────────────────────────────────────────
# 16자 이상. 생성: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-secret

# ── 선택 ─────────────────────────────────────────────────────
# 공휴일 API (한국천문연구원)
# KASI_API_KEY=
